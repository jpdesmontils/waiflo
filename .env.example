# ── Waiflo configuration ──────────────────────────────────────────────
# Copy this file to .env and fill in the values

# Server
PORT=3000

# Path to the data directory (users.json + per-user workflow folders)
# For Docker: use /data (mapped to a volume)
# For bare metal: use any absolute path
DATA_DIR=./waiflo-data

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# AES-256 master secret for encrypting user API keys
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
MASTER_SECRET=change-me-to-another-long-random-string

# Optional: shared Anthropic key for "managed" plan users
# Leave empty if all users will provide their own key
ANTHROPIC_API_KEY=
