# ── Waiflo configuration ──────────────────────────────────────────────
# Copy this file to .env and fill in the values

# Server
PORT=3000

# Path to the data directory (users.json + per-user workflow folders)
# For Docker: use /data (mapped to a volume)
# For bare metal: use any absolute path
DATA_DIR=./waiflo-data

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# AES-256 master secret for encrypting user API keys
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
MASTER_SECRET=change-me-to-another-long-random-string

# Optional: restrict CORS to specific origins (comma-separated)
# Example: CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
# If not set, all origins are allowed (fine for self-hosted behind nginx)
CORS_ORIGIN=

# Optional: shared LLM keys for "managed" plan users (server-level fallback)
# Leave empty if all users will provide their own key in Settings → API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
MISTRAL_API_KEY=
