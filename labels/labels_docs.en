{
  "meta_title":       "Docs — Waiflo",
  "meta_description": "Waiflo documentation: JSON schema reference, step types, REST API, Design API and quickstart guide.",

  "sidebar_schema":          "Schema",
  "sidebar_schema_overview": "Overview",
  "sidebar_steps":           "Steps",
  "sidebar_workflows":       "Workflows",
